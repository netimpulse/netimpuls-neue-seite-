[
  {
    "name": "theme_info",
    "theme_name": "Fashion Brand",
    "theme_author": "netimpulse",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://github.com/netimpulse/claude-training-2",
    "theme_support_url": "https://github.com/netimpulse/claude-training-2/issues"
  },
  {
    "name": "t:settings_schema.colors.name",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "t:settings_schema.colors.settings.background.label",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "t:settings_schema.colors.settings.background_gradient.label",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "text",
            "label": "t:settings_schema.colors.settings.text.label",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button",
            "label": "t:settings_schema.colors.settings.button.label",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "t:settings_schema.colors.settings.button_label.label",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "secondary_button_label",
            "label": "t:settings_schema.colors.settings.secondary_button_label.label",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "shadow",
            "label": "t:settings_schema.colors.settings.shadow.label",
            "default": "#121212"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "secondary_button_label",
          "icons": "text",
          "primary_button": "button",
          "on_primary_button": "button_label",
          "primary_button_border": "button",
          "secondary_button": "background",
          "on_secondary_button": "secondary_button_label",
          "secondary_button_border": "secondary_button_label"
        }
      }
    ]
  },
  {
    "name": "t:settings_schema.typography.name",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "t:settings_schema.typography.settings.type_header_font.label",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "t:settings_schema.typography.settings.type_body_font.label",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "body_scale",
        "label": "t:settings_schema.typography.settings.body_scale.label",
        "min": 100,
        "max": 130,
        "step": 5,
        "unit": "%",
        "default": 100
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "t:settings_schema.typography.settings.heading_scale.label",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "default": 100
      }
    ]
  },
  {
    "name": "t:settings_schema.layout.name",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "t:settings_schema.layout.settings.page_width.label",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "default": 1440,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "label": "t:settings_schema.layout.settings.spacing_sections.label",
        "min": 0,
        "max": 40,
        "step": 4,
        "unit": "px",
        "default": 0
      }
    ]
  },
  {
    "name": "t:settings_schema.social_media.name",
    "settings": [
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "t:settings_schema.social_media.settings.share_image.label"
      },
      {
        "type": "header",
        "content": "t:settings_schema.social_media.settings.accounts.content"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "t:settings_schema.social_media.settings.social_instagram_link.label",
        "info": "https://instagram.com/shopify"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "t:settings_schema.social_media.settings.social_tiktok_link.label",
        "info": "https://tiktok.com/@shopify"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "t:settings_schema.social_media.settings.social_facebook_link.label",
        "info": "https://facebook.com/shopify"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "t:settings_schema.social_media.settings.social_pinterest_link.label",
        "info": "https://pinterest.com/shopify"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "t:settings_schema.social_media.settings.social_youtube_link.label",
        "info": "https://youtube.com/shopify"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "t:settings_schema.social_media.settings.social_twitter_link.label",
        "info": "https://twitter.com/shopify"
      }
    ]
  },
  {
    "name": "t:settings_schema.favicon.name",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:settings_schema.favicon.settings.favicon.label",
        "info": "t:settings_schema.favicon.settings.favicon.info"
      }
    ]
  },
  {
    "name": "t:settings_schema.cart.name",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:settings_schema.cart.settings.cart_type.label",
        "options": [
          { "value": "drawer", "label": "t:settings_schema.cart.settings.cart_type.options__1.label" },
          { "value": "page", "label": "t:settings_schema.cart.settings.cart_type.options__2.label" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "t:settings_schema.cart.settings.show_cart_note.label",
        "default": false
      }
    ]
  }
]
