{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header.js' | asset_url }}" defer></script>

{%- liquid
  assign main_linklist = linklists[section.settings.menu]
  assign drawer_linklist = linklists[section.settings.drawer_menu] | default: main_linklist
  assign sticky = section.settings.sticky_header_type
  assign header_logo = settings.logo | default: section.settings.logo_image | default: section.settings.logo
  assign logo_width = settings.logo_width | default: section.settings.logo_width | default: 140
  assign image_width = logo_width | times: 2
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --sqe-logo-width: {{ logo_width }}px;
    --sqe-header-padding-top: {{ section.settings.padding_top | default: 16 }}px;
    --sqe-header-padding-bottom: {{ section.settings.padding_bottom | default: 16 }}px;
    --sqe-header-margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
  }
{% endstyle %}

{%- capture logo_markup -%}
  <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset" aria-label="{{ shop.name | escape }}">
    {%- if header_logo != blank -%}
      {%- assign logo_alt = header_logo.alt | default: shop.name | escape -%}
      {{ header_logo | image_url: width: image_width | image_tag:
        class: 'header__heading-logo motion-reduce',
        widths: '90,120,140,180,220,280,360,420,520',
        width: logo_width,
        alt: logo_alt,
        sizes: '(min-width: 990px) var(--sqe-logo-width), min(48vw, var(--sqe-logo-width))',
        preload: true
      }}
    {%- else -%}
      <span class="header__heading-text">{{ shop.name }}</span>
    {%- endif -%}
  </a>
{%- endcapture -%}

{% liquid
  assign header_tag = 'div'
  if sticky != 'none'
    assign header_tag = 'sticky-header'
  endif
%}

<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}data-sticky-type="{{ sticky }}"{% endif %}
  class="section-header{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}"
>
  <header class="header header--{{ section.settings.logo_position }} page-width">
    <button
      type="button"
      class="header__icon header__icon--menu link focus-inset"
      aria-controls="HeaderDrawer"
      aria-expanded="false"
      aria-label="{{ 'general.accessibility.open_menu' | t }}"
    >
      {%- render 'icon', name: 'menu' -%}
    </button>

    {%- if request.page_type == 'index' -%}
      <h1 class="header__heading">{{ logo_markup }}</h1>
    {%- else -%}
      <div class="header__heading">{{ logo_markup }}</div>
    {%- endif -%}

    {%- if main_linklist.links.size > 0 -%}
      <nav class="header__inline-menu" aria-label="{{ 'general.accessibility.main_navigation' | t }}">
        <ul class="list-menu list-menu--inline" role="list">
          {%- for link in main_linklist.links -%}
            <li class="header__menu-item-wrapper{% if link.links.size > 0 %} header__menu-item-wrapper--has-children{% endif %}">
              <a href="{{ link.url }}" class="header__menu-item link link--text focus-inset{% if link.active %} header__menu-item--active{% endif %}">
                <span>{{ link.title | escape }}</span>
              </a>
              {%- if link.links.size > 0 -%}
                <ul class="header__submenu list-menu" role="list">
                  {%- for child in link.links -%}
                    <li>
                      <a href="{{ child.url }}" class="header__submenu-item link link--text focus-inset{% if child.active %} header__menu-item--active{% endif %}">
                        {{ child.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <div class="header__icons">
      <details-modal class="header__search">
        <details>
          <summary
            class="header__icon header__icon--search header__icon--summary link focus-inset modal__toggle"
            aria-haspopup="dialog"
            aria-label="{{ 'general.accessibility.open_search' | t }}"
          >
            <span class="svg-wrapper">{%- render 'icon', name: 'search' -%}</span>
            <span class="svg-wrapper header__icon-close">{%- render 'icon', name: 'close' -%}</span>
          </summary>
          <div class="search-modal modal__content gradient" role="dialog" aria-modal="true" aria-label="{{ 'general.search.title' | t }}">
            <div class="modal-overlay"></div>
            <div class="search-modal__content" tabindex="-1">
              {%- if settings.predictive_search_enabled -%}
                <predictive-search class="search-modal__form" data-loading-text="{{ 'general.search.loading' | t }}" data-predictive-search-url="{{ routes.predictive_search_url }}">
              {%- else -%}
                <search-form class="search-modal__form">
              {%- endif -%}
                <form action="{{ routes.search_url }}" method="get" role="search" class="search search-modal__form">
                  <div class="field">
                    <input
                      class="search__input field__input"
                      id="Search-In-Modal"
                      type="search"
                      name="q"
                      value="{{ search.terms | escape }}"
                      placeholder="{{ 'general.search.title' | t }}"
                      {%- if settings.predictive_search_enabled -%}
                        role="combobox"
                        aria-expanded="false"
                        aria-owns="predictive-search-results"
                        aria-controls="predictive-search-results"
                        aria-haspopup="listbox"
                        aria-autocomplete="list"
                        autocorrect="off"
                        autocomplete="off"
                        autocapitalize="off"
                        spellcheck="false"
                      {%- endif -%}
                    >
                    <label class="field__label" for="Search-In-Modal">{{ 'general.search.title' | t }}</label>
                    <input type="hidden" name="options[prefix]" value="last">
                    <button type="reset" class="reset__button field__button{% if search.terms == blank %} hidden{% endif %}" aria-label="{{ 'general.search.reset' | t }}">
                      {%- render 'icon', name: 'close' -%}
                    </button>
                    <button class="search__button field__button" aria-label="{{ 'general.search.submit' | t }}">
                      {%- render 'icon', name: 'search' -%}
                    </button>
                  </div>
                  {%- if settings.predictive_search_enabled -%}
                    <div class="predictive-search predictive-search--header" tabindex="-1" data-predictive-search>
                      <div class="predictive-search__loading-state" hidden>{{ 'general.search.loading' | t }}</div>
                    </div>
                    <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
                  {%- endif -%}
                </form>
              {%- if settings.predictive_search_enabled -%}
                </predictive-search>
              {%- else -%}
                </search-form>
              {%- endif -%}
              <button type="button" class="search-modal__close-button modal__close-button link link--text focus-inset" aria-label="{{ 'general.accessibility.close_search' | t }}">
                {%- render 'icon', name: 'close' -%}
              </button>
            </div>
          </div>
        </details>
      </details-modal>

      <a href="{%- if shop.customer_accounts_enabled -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon header__icon--account link focus-inset" aria-label="{{ 'general.accessibility.account' | t }}">
        {%- render 'icon', name: 'account' -%}
      </a>

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble" aria-label="{{ 'general.accessibility.cart' | t }}">
        {%- render 'icon', name: 'cart' -%}
        <span class="cart-count-bubble{% if cart.item_count == 0 %} hidden{% endif %}" data-cart-count>
          <span aria-hidden="true">{{ cart.item_count }}</span>
          <span class="visually-hidden">{{ 'cart.items_count' | t: count: cart.item_count }}</span>
        </span>
      </a>
    </div>
  </header>

  <div id="HeaderDrawer" class="menu-drawer" aria-hidden="true" hidden>
    <div class="menu-drawer__overlay" data-drawer-close></div>
    <aside class="menu-drawer__inner" role="dialog" aria-modal="true" aria-label="{{ 'general.accessibility.menu' | t }}">
      <div class="menu-drawer__header">
        <span class="menu-drawer__title">{{ 'general.menu.title' | t }}</span>
        <button type="button" class="header__icon link focus-inset" data-drawer-close aria-label="{{ 'general.accessibility.close_menu' | t }}">
          {%- render 'icon', name: 'close' -%}
        </button>
      </div>
      <nav class="menu-drawer__navigation" aria-label="{{ 'general.accessibility.drawer_navigation' | t }}">
        <ul class="menu-drawer__menu list-menu" role="list">
          {%- for link in drawer_linklist.links -%}
            <li>
              {%- if link.links.size > 0 -%}
                <button type="button" class="menu-drawer__menu-item menu-drawer__menu-item--button link link--text focus-inset" aria-expanded="false">
                  <span>{{ link.title | escape }}</span>
                  {%- render 'icon', name: 'chevron-down' -%}
                </button>
                <ul class="menu-drawer__submenu list-menu" role="list" hidden>
                  <li><a href="{{ link.url }}" class="menu-drawer__menu-item link link--text focus-inset">{{ 'general.menu.view_all' | t }} {{ link.title | escape }}</a></li>
                  {%- for child in link.links -%}
                    <li><a href="{{ child.url }}" class="menu-drawer__menu-item link link--text focus-inset">{{ child.title | escape }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- else -%}
                <a href="{{ link.url }}" class="menu-drawer__menu-item link link--text focus-inset">{{ link.title | escape }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    </aside>
  </div>
</{{ header_tag }}>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.header.name",
  "tag": "header",
  "class": "section-site-header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "select",
      "id": "logo_position",
      "options": [
        { "value": "middle-left", "label": "t:sections.header.settings.logo_position.options__1.label" },
        { "value": "top-left", "label": "t:sections.header.settings.logo_position.options__2.label" },
        { "value": "top-center", "label": "t:sections.header.settings.logo_position.options__3.label" },
        { "value": "middle-center", "label": "t:sections.header.settings.logo_position.options__4.label" }
      ],
      "default": "middle-left",
      "label": "t:sections.header.settings.logo_position.label"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "link_list",
      "id": "drawer_menu",
      "label": "t:sections.header.settings.drawer_menu.label",
      "info": "t:sections.header.settings.drawer_menu.info"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none", "label": "t:sections.header.settings.sticky_header_type.options__1.label" },
        { "value": "on-scroll-up", "label": "t:sections.header.settings.sticky_header_type.options__2.label" },
        { "value": "always", "label": "t:sections.header.settings.sticky_header_type.options__3.label" }
      ],
      "default": "on-scroll-up",
      "label": "t:sections.header.settings.sticky_header_type.label"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.spacing_header.content"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.margin_bottom.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.padding_top.label",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.padding_bottom.label",
      "default": 16
    }
  ]
}
{% endschema %}
