{%- comment -%}
  Header section — fashion brand
  Features:
    - Logo (image or shop name text)
    - Main navigation (centered, can be shown/hidden via setting)
    - Burger menu button opens a drawer with a secondary menu (for categories like Herren/Damen)
    - Search icon opens a search drawer
    - Account icon
    - Cart icon with live item count
    - Optional announcement text above
    - Fully responsive: on mobile the main nav collapses into the burger drawer
{%- endcomment -%}

{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header.js' | asset_url }}" defer></script>

{%- liquid
  assign scheme = section.settings.color_scheme
  assign main_linklist = linklists[section.settings.main_menu]
  assign drawer_linklist = linklists[section.settings.drawer_menu]
  assign show_main_nav = section.settings.show_main_nav
  assign sticky = section.settings.sticky_header
-%}

{% style %}
  {%- if scheme -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
  }
  {%- endif -%}
  #shopify-section-{{ section.id }} {
    --logo-height: {{ section.settings.logo_height | default: 40 }}px;
    --header-height: {{ section.settings.logo_height | default: 40 | plus: 48 }}px;
  }
{% endstyle %}

<site-header class="site-header color-scheme color-{{ scheme.id }}{% if sticky %} site-header--sticky{% endif %}" data-section-id="{{ section.id }}">
  <div class="site-header__inner">
    {%- comment -%} LEFT: burger + (optional) left-aligned logo {%- endcomment -%}
    <div class="site-header__left">
      <button type="button"
        class="site-header__icon-btn site-header__burger"
        aria-controls="HeaderDrawer"
        aria-expanded="false"
        aria-label="{{ 'general.accessibility.open_menu' | t }}">
        {%- render 'icon', name: 'menu' -%}
      </button>
    </div>

    {%- comment -%} CENTER: logo + (optional) main nav {%- endcomment -%}
    <div class="site-header__center">
      {%- if section.settings.logo != blank -%}
        {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
        {%- assign logo_width = section.settings.logo_height | times: 4 -%}
        <a href="{{ routes.root_url }}" class="site-header__logo-link" aria-label="{{ shop.name | escape }}">
          {{ section.settings.logo | image_url: width: logo_width | image_tag:
             alt: logo_alt,
             loading: 'eager',
             class: 'site-header__logo',
             widths: '120,240,360',
             sizes: '(min-width: 750px) 200px, 140px' }}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="site-header__logo-link site-header__logo-text">
          <span>{{ shop.name }}</span>
        </a>
      {%- endif -%}

      {%- if show_main_nav and main_linklist.links.size > 0 -%}
        <nav class="site-header__nav" aria-label="{{ 'general.accessibility.main_navigation' | t }}">
          <ul class="site-header__nav-list" role="list">
            {%- for link in main_linklist.links -%}
              <li class="site-header__nav-item{% if link.links.size > 0 %} site-header__nav-item--has-children{% endif %}">
                <a href="{{ link.url }}" class="site-header__nav-link{% if link.active %} site-header__nav-link--active{% endif %}">{{ link.title | escape }}</a>
                {%- if link.links.size > 0 -%}
                  <div class="site-header__dropdown">
                    <ul class="site-header__dropdown-list" role="list">
                      {%- for child in link.links -%}
                        <li><a href="{{ child.url }}" class="site-header__dropdown-link">{{ child.title | escape }}</a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT: search + account + cart {%- endcomment -%}
    <div class="site-header__right">
      <button type="button"
        class="site-header__icon-btn"
        aria-controls="HeaderSearch"
        aria-expanded="false"
        aria-label="{{ 'general.accessibility.open_search' | t }}">
        {%- render 'icon', name: 'search' -%}
      </button>

      <a href="{%- if shop.customer_accounts_enabled -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
         class="site-header__icon-btn"
         aria-label="{{ 'general.accessibility.account' | t }}">
        {%- render 'icon', name: 'account' -%}
      </a>

      <a href="{{ routes.cart_url }}"
         class="site-header__icon-btn site-header__cart-btn"
         aria-label="{{ 'general.accessibility.cart' | t }}">
        {%- render 'icon', name: 'cart' -%}
        <span class="site-header__cart-count"
              data-cart-count
              aria-live="polite"
              aria-atomic="true"
              {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  {%- comment -%} ============ DRAWER (burger menu — second menu) ============ {%- endcomment -%}
  <div id="HeaderDrawer" class="site-drawer" aria-hidden="true" hidden>
    <div class="site-drawer__overlay" data-drawer-close></div>
    <aside class="site-drawer__panel" role="dialog" aria-modal="true" aria-label="{{ 'general.accessibility.menu' | t }}">
      <div class="site-drawer__header">
        <span class="site-drawer__title">{{ 'general.menu.title' | t }}</span>
        <button type="button" class="site-header__icon-btn" data-drawer-close aria-label="{{ 'general.accessibility.close_menu' | t }}">
          {%- render 'icon', name: 'close' -%}
        </button>
      </div>
      <nav class="site-drawer__nav" aria-label="{{ 'general.accessibility.drawer_navigation' | t }}">
        {%- if drawer_linklist.links.size > 0 -%}
          <ul class="site-drawer__list" role="list">
            {%- for link in drawer_linklist.links -%}
              <li class="site-drawer__item{% if link.links.size > 0 %} site-drawer__item--has-children{% endif %}">
                {%- if link.links.size > 0 -%}
                  <button type="button" class="site-drawer__toggle" aria-expanded="false">
                    <span>{{ link.title | escape }}</span>
                    {%- render 'icon', name: 'chevron-down' -%}
                  </button>
                  <ul class="site-drawer__sublist" role="list" hidden>
                    <li><a href="{{ link.url }}" class="site-drawer__sublink site-drawer__sublink--all">{{ 'general.menu.view_all' | t }} {{ link.title | escape }}</a></li>
                    {%- for child in link.links -%}
                      <li><a href="{{ child.url }}" class="site-drawer__sublink">{{ child.title | escape }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- else -%}
                  <a href="{{ link.url }}" class="site-drawer__link">{{ link.title | escape }}</a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if show_main_nav == false and main_linklist.links.size > 0 -%}
          {%- comment -%} If main nav is hidden on desktop header, show it here too {%- endcomment -%}
          <ul class="site-drawer__list site-drawer__list--secondary" role="list">
            {%- for link in main_linklist.links -%}
              <li class="site-drawer__item">
                <a href="{{ link.url }}" class="site-drawer__link">{{ link.title | escape }}</a>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </nav>

      {%- if section.settings.drawer_promo_heading != blank or section.settings.drawer_promo_text != blank -%}
        <div class="site-drawer__promo">
          {%- if section.settings.drawer_promo_heading != blank -%}
            <p class="eyebrow">{{ section.settings.drawer_promo_heading | escape }}</p>
          {%- endif -%}
          {%- if section.settings.drawer_promo_text != blank -%}
            <p>{{ section.settings.drawer_promo_text | escape }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </aside>
  </div>

  {%- comment -%} ============ SEARCH DRAWER ============ {%- endcomment -%}
  <div id="HeaderSearch" class="site-search" aria-hidden="true" hidden>
    <div class="site-search__overlay" data-search-close></div>
    <div class="site-search__panel" role="dialog" aria-modal="true" aria-label="{{ 'general.search.title' | t }}">
      <form action="{{ routes.search_url }}" method="get" role="search" class="site-search__form">
        <label for="HeaderSearchInput" class="visually-hidden">{{ 'general.search.title' | t }}</label>
        <input id="HeaderSearchInput"
               type="search"
               name="q"
               class="site-search__input"
               placeholder="{{ 'general.search.placeholder' | t }}"
               autocomplete="off"
               autocorrect="off"
               spellcheck="false">
        <button type="submit" class="site-search__submit" aria-label="{{ 'general.accessibility.submit_search' | t }}">
          {%- render 'icon', name: 'search' -%}
        </button>
        <button type="button" class="site-header__icon-btn site-search__close" data-search-close aria-label="{{ 'general.accessibility.close_search' | t }}">
          {%- render 'icon', name: 'close' -%}
        </button>
      </form>
    </div>
  </div>
</site-header>

{% schema %}
{
  "name": "t:sections.header.name",
  "tag": "header",
  "class": "section-site-header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.header.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.logo_header.content"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.header.settings.logo.label"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.logo_height.label",
      "default": 40
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.menus_header.content"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "t:sections.header.settings.main_menu.label",
      "info": "t:sections.header.settings.main_menu.info"
    },
    {
      "type": "checkbox",
      "id": "show_main_nav",
      "label": "t:sections.header.settings.show_main_nav.label",
      "default": true
    },
    {
      "type": "link_list",
      "id": "drawer_menu",
      "label": "t:sections.header.settings.drawer_menu.label",
      "info": "t:sections.header.settings.drawer_menu.info"
    },
    {
      "type": "text",
      "id": "drawer_promo_heading",
      "label": "t:sections.header.settings.drawer_promo_heading.label"
    },
    {
      "type": "textarea",
      "id": "drawer_promo_text",
      "label": "t:sections.header.settings.drawer_promo_text.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.behavior_header.content"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "t:sections.header.settings.sticky_header.label",
      "default": true
    }
  ]
}
{% endschema %}
