{{ 'section-header.css' | asset_url | stylesheet_tag }}
{{ 'component-predictive-search.css' | asset_url | stylesheet_tag }}
<script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'section-header.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign scheme = section.settings.color_scheme
  assign menu_scheme = section.settings.menu_color_scheme | default: scheme
  assign main_linklist = linklists[section.settings.menu]
  assign drawer_linklist = main_linklist
  assign header_logo = settings.logo | default: section.settings.logo_image
  assign logo_width = settings.logo_width | default: section.settings.logo_width | default: 140
  assign image_width = logo_width | times: 2
  assign header_tag = 'div'
  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif

  assign has_app_block = false
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor

  assign localization_forms = false
  if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
    assign localization_forms = true
  endif
-%}

{% style %}
  {%- if scheme != blank and scheme.settings != blank and scheme.settings.background != blank -%}
    .color-{{ scheme.id }} {
      --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
      --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
      --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
      --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
    }
  {%- endif -%}
  {%- if menu_scheme != blank and menu_scheme.settings != blank and menu_scheme.settings.background != blank -%}
    .color-{{ menu_scheme.id }} {
      --color-background: {{ menu_scheme.settings.background.red }}, {{ menu_scheme.settings.background.green }}, {{ menu_scheme.settings.background.blue }};
      --color-text: {{ menu_scheme.settings.text.red }}, {{ menu_scheme.settings.text.green }}, {{ menu_scheme.settings.text.blue }};
      --color-button: {{ menu_scheme.settings.button.red }}, {{ menu_scheme.settings.button.green }}, {{ menu_scheme.settings.button.blue }};
      --color-button-label: {{ menu_scheme.settings.button_label.red }}, {{ menu_scheme.settings.button_label.green }}, {{ menu_scheme.settings.button_label.blue }};
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} {
    --logo-width: {{ logo_width }}px;
    --header-icon-color: {{ section.settings.icon_color }};
    --header-padding-top: {{ section.settings.padding_top }}px;
    --header-padding-bottom: {{ section.settings.padding_bottom }}px;
    --header-margin-bottom: {{ section.settings.margin_bottom }}px;
  }
{% endstyle %}

{%- capture logo_markup -%}
  <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset" aria-label="{{ shop.name | escape }}">
    {%- if header_logo != blank -%}
      <span class="header__heading-logo-wrapper">
        {%- assign logo_alt = header_logo.alt | default: shop.name | escape -%}
        {{ header_logo | image_url: width: image_width | image_tag:
          class: 'header__heading-logo motion-reduce',
          widths: '90,120,140,180,220,280,360,420,520',
          width: logo_width,
          alt: logo_alt,
          sizes: '(min-width: 990px) var(--logo-width), min(50vw, var(--logo-width))',
          preload: true
        }}
      </span>
    {%- else -%}
      <span class="header__heading-text h2">{{ shop.name }}</span>
    {%- endif -%}
  </a>
{%- endcapture -%}

<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}data-sticky-type="{{ section.settings.sticky_header_type }}"{% endif %}
  class="section-header header-wrapper color-{{ scheme.id }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}"
>
  <header class="header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if main_linklist.links.size > 0 %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if localization_forms %} header--has-localizations{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}">
    <button
      type="button"
      class="header__icon header__icon--menu link focus-inset"
      aria-controls="HeaderDrawer"
      aria-expanded="false"
      aria-label="{{ 'general.accessibility.open_menu' | t }}"
    >
      {%- render 'icon', name: 'menu' -%}
    </button>

    {%- if section.settings.logo_position == 'top-center' or main_linklist.links.size == 0 -%}
      {%- render 'header-search', input_id: 'Search-In-Modal-1' -%}
    {%- endif -%}

    {%- if section.settings.logo_position != 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">{{ logo_markup }}</h1>
      {%- else -%}
        <div class="header__heading">{{ logo_markup }}</div>
      {%- endif -%}
    {%- endif -%}

    {%- if main_linklist.links.size > 0 and section.settings.menu_type_desktop != 'drawer' -%}
      <nav class="header__inline-menu header__inline-menu--{{ section.settings.menu_type_desktop }}" aria-label="{{ 'general.accessibility.main_navigation' | t }}">
        <ul class="list-menu list-menu--inline" role="list">
          {%- for link in main_linklist.links -%}
            <li class="header__menu-item-wrapper{% if link.links.size > 0 %} header__menu-item-wrapper--has-children{% endif %}">
              <a href="{{ link.url }}" class="header__menu-item link link--text focus-inset{% if link.active %} header__menu-item--active{% endif %}">
                <span>{{ link.title | escape }}</span>
                {%- if link.links.size > 0 -%}{%- render 'icon', name: 'chevron-down' -%}{%- endif -%}
              </a>
              {%- if link.links.size > 0 -%}
                <div class="header__submenu color-{{ menu_scheme.id }} gradient{% if section.settings.menu_type_desktop == 'mega' %} header__submenu--mega{% endif %}">
                  <ul class="header__submenu-list list-menu" role="list">
                    {%- for child in link.links -%}
                      <li>
                        <a href="{{ child.url }}" class="header__submenu-item link link--text focus-inset{% if child.active %} header__menu-item--active{% endif %}">
                          {{ child.title | escape }}
                        </a>
                        {%- if section.settings.menu_type_desktop == 'mega' and child.links.size > 0 -%}
                          <ul class="header__submenu-grandchild list-menu" role="list">
                            {%- for grandchild in child.links -%}
                              <li><a href="{{ grandchild.url }}" class="header__submenu-grandchild-link link link--text focus-inset{% if grandchild.active %} header__menu-item--active{% endif %}">{{ grandchild.title | escape }}</a></li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    {%- if section.settings.logo_position == 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">{{ logo_markup }}</h1>
      {%- else -%}
        <div class="header__heading">{{ logo_markup }}</div>
      {%- endif -%}
    {%- endif -%}

    <div class="header__icons{% if localization_forms %} header__icons--localization header-localization{% endif %}">
      <div class="desktop-localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
            <label class="visually-hidden" for="HeaderCountrySelector">{{ 'localization.country_label' | t }}</label>
            <select id="HeaderCountrySelector" name="country_code" class="localization-form__select">
              {%- for country in localization.available_countries -%}
                <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>{{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})</option>
              {%- endfor -%}
            </select>
          {%- endform -%}
        {%- endif -%}
        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
            <label class="visually-hidden" for="HeaderLanguageSelector">{{ 'localization.language_label' | t }}</label>
            <select id="HeaderLanguageSelector" name="locale_code" class="localization-form__select">
              {%- for language in localization.available_languages -%}
                <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>{{ language.endonym_name | capitalize }}</option>
              {%- endfor -%}
            </select>
          {%- endform -%}
        {%- endif -%}
      </div>

      {%- unless section.settings.logo_position == 'top-center' or main_linklist.links.size == 0 -%}
        {%- render 'header-search', input_id: 'Search-In-Modal' -%}
      {%- endunless -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon header__icon--account link focus-inset" aria-label="{%- if customer -%}{{ 'customer.account_fallback' | t }}{%- else -%}{{ 'customer.log_in' | t }}{%- endif -%}">
          {%- if section.settings.enable_customer_avatar and customer and customer.has_avatar? -%}
            {{ customer | avatar }}
          {%- else -%}
            {%- render 'icon', name: 'account' -%}
          {%- endif -%}
        </a>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble" aria-label="{{ 'general.accessibility.cart' | t }}">
        {%- render 'icon', name: 'cart' -%}
        <span class="cart-count-bubble{% if cart.item_count == 0 %} hidden{% endif %}" data-cart-count>
          {%- if cart.item_count < 100 -%}<span aria-hidden="true">{{ cart.item_count }}</span>{%- endif -%}
          <span class="visually-hidden">{{ 'cart.items_count' | t: count: cart.item_count }}</span>
        </span>
      </a>
    </div>
  </header>
</{{ header_tag }}>

<div id="HeaderDrawer" class="menu-drawer color-{{ menu_scheme.id }} gradient" aria-hidden="true" hidden>
  <div class="menu-drawer__overlay" data-drawer-close></div>
  <aside class="menu-drawer__inner" role="dialog" aria-modal="true" aria-label="{{ 'general.accessibility.menu' | t }}">
    <div class="menu-drawer__header">
      <span class="menu-drawer__title">{{ 'general.menu.title' | t }}</span>
      <button type="button" class="header__icon link focus-inset" data-drawer-close aria-label="{{ 'general.accessibility.close_menu' | t }}">
        {%- render 'icon', name: 'close' -%}
      </button>
    </div>
    <nav class="menu-drawer__navigation" aria-label="{{ 'general.accessibility.drawer_navigation' | t }}">
      <ul class="menu-drawer__menu list-menu" role="list">
        {%- for link in drawer_linklist.links -%}
          <li>
            {%- if link.links.size > 0 -%}
              <button type="button" class="menu-drawer__menu-item menu-drawer__menu-item--button" aria-expanded="false">
                <span>{{ link.title | escape }}</span>
                {%- render 'icon', name: 'chevron-down' -%}
              </button>
              <ul class="menu-drawer__submenu list-menu" hidden>
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="menu-drawer__menu-item{% if child.active %} menu-drawer__menu-item--active{% endif %}">{{ child.title | escape }}</a>
                    {%- if child.links.size > 0 -%}
                      <ul class="menu-drawer__submenu menu-drawer__submenu--grandchild list-menu">
                        {%- for grandchild in child.links -%}
                          <li><a href="{{ grandchild.url }}" class="menu-drawer__menu-item{% if grandchild.active %} menu-drawer__menu-item--active{% endif %}">{{ grandchild.title | escape }}</a></li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <a href="{{ link.url }}" class="menu-drawer__menu-item{% if link.active %} menu-drawer__menu-item--active{% endif %}">{{ link.title | escape }}</a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  </aside>
</div>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: routes.root_url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-site-header",
  "max_blocks": 3,
  "settings": [
    {
      "type": "select",
      "id": "logo_position",
      "options": [
        { "value": "top-left", "label": "t:sections.header.settings.logo_position.options__2.label" },
        { "value": "top-center", "label": "t:sections.header.settings.logo_position.options__3.label" },
        { "value": "middle-left", "label": "t:sections.header.settings.logo_position.options__1.label" },
        { "value": "middle-center", "label": "t:sections.header.settings.logo_position.options__4.label" }
      ],
      "default": "middle-left",
      "label": "t:sections.header.settings.logo_position.label",
      "info": "t:sections.header.settings.logo_help.content"
    },
    {
      "type": "select",
      "id": "mobile_logo_position",
      "options": [
        { "value": "center", "label": "t:sections.header.settings.mobile_logo_position.options__1.label" },
        { "value": "left", "label": "t:sections.header.settings.mobile_logo_position.options__2.label" }
      ],
      "default": "center",
      "label": "t:sections.header.settings.mobile_logo_position.label"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "select",
      "id": "menu_type_desktop",
      "options": [
        { "value": "dropdown", "label": "t:sections.header.settings.menu_type_desktop.options__1.label" },
        { "value": "mega", "label": "t:sections.header.settings.menu_type_desktop.options__2.label" },
        { "value": "drawer", "label": "t:sections.header.settings.menu_type_desktop.options__3.label" }
      ],
      "default": "dropdown",
      "label": "t:sections.header.settings.menu_type_desktop.label"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none", "label": "t:sections.header.settings.sticky_header_type.options__1.label" },
        { "value": "on-scroll-up", "label": "t:sections.header.settings.sticky_header_type.options__2.label" },
        { "value": "always", "label": "t:sections.header.settings.sticky_header_type.options__3.label" },
        { "value": "reduce-logo-size", "label": "t:sections.header.settings.sticky_header_type.options__4.label" }
      ],
      "default": "on-scroll-up",
      "label": "t:sections.header.settings.sticky_header_type.label"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "t:sections.header.settings.menu_color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "t:sections.header.settings.icon_color.label",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__utilities.content"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_country_selector.label",
      "info": "t:sections.header.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_language_selector.label",
      "info": "t:sections.header.settings.enable_language_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_customer_avatar",
      "default": true,
      "label": "t:sections.header.settings.enable_customer_avatar.label",
      "info": "t:sections.header.settings.enable_customer_avatar.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.margin_bottom.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 20
    }
  ],
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
