{%- comment -%}
  Theme Store Section — client-side filter
  ----------------------------------------
  - Renders ALL products from the configured collection in one grid.
  - JS filters the grid by:
      * the active tag (sidebar click), and/or
      * the search query (typed in the search input, typo-tolerant).
  - No full page reloads. URL state is mirrored via ?tag=<tag> for
    bookmarkability; popstate is handled.

  Schema:
    settings.collection         the master collection (e.g. handle 'themes')
    settings.default_label      label for the "All themes" tab
    settings.products_max       hard cap on rendered products (default 50)
    blocks.tag_override         optional: rename / hide / reorder a tag
    blocks.feature              optional: free-text bullet in sidebar

  Notes:
  - target_collection.all_tags is read for the filter list.
  - Each card carries data-product-tags / data-product-search so JS can
    filter without an API call.
  - This works on any template (homepage / page / collection) because
    everything is local.
{%- endcomment -%}

{{ 'section-theme-store.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-theme-store.js' | asset_url }}" defer></script>

{%- liquid
  assign scheme = section.settings.color_scheme
  assign default_label = section.settings.default_label | default: 'Alle Themes'
  assign categories_heading = section.settings.categories_heading
  assign features_heading = section.settings.features_heading
  assign products_max = section.settings.products_max | default: 50

  assign target_collection = collections[section.settings.collection]
  if target_collection == blank
    assign target_collection = collection
  endif

  comment
    Build a comma-delimited list of tags overridden by blocks (lowercased)
    so we can dedupe when listing target_collection.all_tags later.
    Also build a list of tags marked as "hide" so we drop them entirely.
  endcomment
  capture overridden_tags
    echo ','
    for block in section.blocks
      if block.type == 'tag_override' and block.settings.tag != blank
        echo block.settings.tag | downcase
        echo ','
      endif
    endfor
  endcapture

  capture hidden_tags
    echo ','
    for block in section.blocks
      if block.type == 'tag_override' and block.settings.tag != blank and block.settings.hide
        echo block.settings.tag | downcase
        echo ','
      endif
    endfor
  endcapture
-%}

{% style %}
  {%- if scheme != blank and scheme.settings != blank and scheme.settings.background != blank -%}
  #shopify-section-{{ section.id }} .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
  }
  {%- endif -%}
  #shopify-section-{{ section.id }} {
    --ts-padding-top: {{ section.settings.padding_top | default: 48 }}px;
    --ts-padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
    --ts-cols-desktop: {{ section.settings.products_per_row | default: 3 }};
  }
{% endstyle %}

<theme-store class="theme-store color-scheme color-{{ scheme.id }}" data-section-id="{{ section.id }}">

  {%- if section.settings.heading != blank -%}
    <header class="theme-store__heading-wrap">
      <h2 class="theme-store__heading">{{ section.settings.heading | escape }}</h2>
    </header>
  {%- endif -%}

  {%- comment -%} ============ SEARCH BAR ============ {%- endcomment -%}
  <div class="theme-store__search-wrap">
    <form action="{{ routes.search_url }}" method="get" role="search" class="theme-store__search" data-search-form onsubmit="return false;">
      <label for="ThemeStoreSearch-{{ section.id }}" class="visually-hidden">{{ 'sections.theme_store.search_label' | t }}</label>
      <span class="theme-store__search-icon" aria-hidden="true">{%- render 'icon', name: 'search' -%}</span>
      <input
        id="ThemeStoreSearch-{{ section.id }}"
        type="search"
        name="q"
        class="theme-store__search-input"
        placeholder="{{ 'sections.theme_store.search_placeholder' | t }}"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
        maxlength="120"
        data-search-input>
      <button type="button" class="theme-store__search-clear" data-search-clear hidden aria-label="{{ 'sections.theme_store.clear_search' | t }}">
        {%- render 'icon', name: 'close' -%}
      </button>
    </form>
  </div>

  {%- comment -%} ============ MOBILE FILTER TOGGLE ============ {%- endcomment -%}
  <button type="button" class="theme-store__filter-toggle" data-filter-open aria-controls="ThemeStoreSidebar-{{ section.id }}" aria-expanded="false">
    {%- render 'icon', name: 'menu' -%}
    <span>{{ 'sections.theme_store.filter_label' | t }}</span>
  </button>

  <div class="theme-store__layout">

    {%- comment -%} ============ SIDEBAR ============ {%- endcomment -%}
    <aside id="ThemeStoreSidebar-{{ section.id }}" class="theme-store__sidebar" aria-label="{{ 'sections.theme_store.filter_label' | t }}" data-sidebar>
      <div class="theme-store__sidebar-header">
        <span class="theme-store__sidebar-title">{{ 'sections.theme_store.filter_label' | t }}</span>
        <button type="button" class="theme-store__sidebar-close" data-filter-close aria-label="{{ 'general.accessibility.close_menu' | t }}">
          {%- render 'icon', name: 'close' -%}
        </button>
      </div>

      {%- if categories_heading != blank -%}
        <h3 class="theme-store__sidebar-heading">{{ categories_heading | escape }}</h3>
      {%- endif -%}

      <ul class="theme-store__cat-list" role="list">
        {%- comment -%} "Alle Themes" tab — empty tag = show everything {%- endcomment -%}
        {%- if target_collection != blank -%}
          <li>
            <a href="?tag="
               class="theme-store__cat-link theme-store__cat-link--active"
               data-cat-link
               data-cat-tag=""
               aria-current="page">
              <span class="theme-store__cat-label">{{ default_label | escape }}</span>
              <span class="theme-store__cat-count" aria-hidden="true" data-cat-count>{{ target_collection.all_products_count }}</span>
            </a>
          </li>
        {%- endif -%}

        {%- if target_collection != blank -%}
          {%- comment -%} 1) Override blocks first, in editor order {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'tag_override' and block.settings.tag != blank and block.settings.hide != true -%}
              {%- assign override_tag_lc = block.settings.tag | downcase -%}
              {%- assign matched_tag = '' -%}
              {%- for t in target_collection.all_tags -%}
                {%- assign t_lc = t | downcase -%}
                {%- if t_lc == override_tag_lc -%}
                  {%- assign matched_tag = t -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if matched_tag != blank -%}
                {%- assign cat_label = block.settings.custom_label | default: matched_tag -%}
                <li {{ block.shopify_attributes }}>
                  <a href="?tag={{ matched_tag | downcase | url_encode }}"
                     class="theme-store__cat-link"
                     data-cat-link
                     data-cat-tag="{{ matched_tag | downcase | escape }}">
                    <span class="theme-store__cat-label">{{ cat_label | escape }}</span>
                    <span class="theme-store__cat-count" aria-hidden="true" data-cat-count></span>
                  </a>
                </li>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} 2) Remaining tags from collection.all_tags, alphabetical, dedupe overrides + hidden {%- endcomment -%}
          {%- for tag in target_collection.all_tags -%}
            {%- assign tag_lc = tag | downcase -%}
            {%- assign needle = ',' | append: tag_lc | append: ',' -%}
            {%- unless overridden_tags contains needle or hidden_tags contains needle -%}
              <li>
                <a href="?tag={{ tag | downcase | url_encode }}"
                   class="theme-store__cat-link"
                   data-cat-link
                   data-cat-tag="{{ tag_lc | escape }}">
                  <span class="theme-store__cat-label">{{ tag | escape }}</span>
                  <span class="theme-store__cat-count" aria-hidden="true" data-cat-count></span>
                </a>
              </li>
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      </ul>

      {%- assign feature_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' and block.settings.text != blank -%}
          {%- assign feature_count = feature_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if feature_count > 0 -%}
        {%- if features_heading != blank -%}
          <h3 class="theme-store__sidebar-heading theme-store__sidebar-heading--features">{{ features_heading | escape }}</h3>
        {%- endif -%}
        <ul class="theme-store__feat-list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' and block.settings.text != blank -%}
              <li class="theme-store__feat-item" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </aside>

    <div class="theme-store__sidebar-overlay" data-sidebar-overlay hidden></div>

    {%- comment -%} ============ PRODUCT GRID — render ALL products, JS filters ============ {%- endcomment -%}
    <div class="theme-store__main">
      {%- if target_collection != blank and target_collection.products.size > 0 -%}
        <div class="theme-store__grid" role="list" data-grid>
          {%- for product in target_collection.products limit: products_max -%}
            {%- liquid
              assign featured = product.featured_media
              assign img_alt = product.title | escape
              assign price = product.price | money

              capture pt_tags
                for t in product.tags
                  echo t | downcase
                  echo ' '
                endfor
              endcapture

              assign pt_subtitle = ''
              if product.metafields.theme.subtitle.value != blank
                assign pt_subtitle = product.metafields.theme.subtitle.value
              elsif product.type != blank
                assign pt_subtitle = product.type
              endif

              capture pt_search
                echo product.title | downcase
                echo ' '
                echo pt_subtitle | downcase
                echo ' '
                echo pt_tags
                echo product.vendor | downcase
              endcapture
            -%}
            <article
              class="theme-store__card"
              role="listitem"
              data-product-card
              data-product-title="{{ product.title | escape }}"
              data-product-tags="{{ pt_tags | strip | escape }}"
              data-product-search="{{ pt_search | strip | escape }}">
              <a class="theme-store__card-link" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                <div class="theme-store__card-media">
                  {%- if featured != blank and featured.preview_image != blank -%}
                    {{ featured.preview_image | image_url: width: 600 | image_tag:
                       alt: img_alt,
                       loading: 'lazy',
                       widths: '320,480,600,800',
                       sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                       class: 'theme-store__card-image' }}
                  {%- else -%}
                    <div class="theme-store__card-placeholder" aria-hidden="true"></div>
                  {%- endif -%}
                </div>
                <div class="theme-store__card-body">
                  <h3 class="theme-store__card-title">{{ product.title | escape }}</h3>
                  {%- if pt_subtitle != blank -%}
                    <p class="theme-store__card-subtitle">{{ pt_subtitle | escape }}</p>
                  {%- endif -%}
                  <p class="theme-store__card-price">{{ price }}</p>
                </div>
              </a>
            </article>
          {%- endfor -%}
        </div>

        <div class="theme-store__no-results" data-no-results hidden>
          <p>{{ 'sections.theme_store.no_results' | t }}</p>
          <button type="button" class="theme-store__no-results-reset" data-reset-filters>
            {{ 'sections.theme_store.reset_filters' | t }}
            {%- render 'icon', name: 'arrow-right' -%}
          </button>
        </div>
      {%- else -%}
        <div class="theme-store__empty">
          <p>{{ 'sections.theme_store.empty_state' | t }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</theme-store>

{% schema %}
{
  "name": "t:sections.theme_store.name",
  "tag": "section",
  "class": "section-theme-store",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.theme_store.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.theme_store.settings.content_header.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.theme_store.settings.heading.label",
      "default": "Theme Store"
    },
    {
      "type": "header",
      "content": "t:sections.theme_store.settings.collection_header.content"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.theme_store.settings.collection.label",
      "info": "t:sections.theme_store.settings.collection.info"
    },
    {
      "type": "text",
      "id": "default_label",
      "label": "t:sections.theme_store.settings.default_label.label",
      "default": "Alle Themes"
    },
    {
      "type": "text",
      "id": "categories_heading",
      "label": "t:sections.theme_store.settings.categories_heading.label",
      "default": "Kategorien"
    },
    {
      "type": "text",
      "id": "features_heading",
      "label": "t:sections.theme_store.settings.features_heading.label",
      "default": "Features"
    },
    {
      "type": "header",
      "content": "t:sections.theme_store.settings.layout_header.content"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "t:sections.theme_store.settings.products_per_row.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "products_max",
      "label": "t:sections.theme_store.settings.products_max.label",
      "info": "t:sections.theme_store.settings.products_max.info",
      "min": 6,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "header",
      "content": "t:sections.theme_store.settings.spacing_header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.theme_store.settings.padding_top.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.theme_store.settings.padding_bottom.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "tag_override",
      "name": "t:sections.theme_store.blocks.tag_override.name",
      "limit": 50,
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "t:sections.theme_store.blocks.tag_override.settings.tag.label",
          "info": "t:sections.theme_store.blocks.tag_override.settings.tag.info"
        },
        {
          "type": "text",
          "id": "custom_label",
          "label": "t:sections.theme_store.blocks.tag_override.settings.custom_label.label",
          "info": "t:sections.theme_store.blocks.tag_override.settings.custom_label.info"
        },
        {
          "type": "checkbox",
          "id": "hide",
          "label": "t:sections.theme_store.blocks.tag_override.settings.hide.label",
          "info": "t:sections.theme_store.blocks.tag_override.settings.hide.info",
          "default": false
        }
      ]
    },
    {
      "type": "feature",
      "name": "t:sections.theme_store.blocks.feature.name",
      "limit": 20,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.theme_store.blocks.feature.settings.text.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.theme_store.presets.default.name",
      "blocks": [
        { "type": "feature", "settings": { "text": "Mobile optimiert" } },
        { "type": "feature", "settings": { "text": "SEO-freundlich" } },
        { "type": "feature", "settings": { "text": "Theme-Editor kompatibel" } },
        { "type": "feature", "settings": { "text": "Schnelle Ladezeiten" } }
      ]
    }
  ]
